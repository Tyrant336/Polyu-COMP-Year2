[gd_scene format=3 uid="uid://loginscene01"]

[ext_resource type="Script" path="res://scripts/login_ui.gd" id="1_login"]

[node name="Login" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_login")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.12, 0.35, 0.52, 1)

[node name="CenterPanel" type="PanelContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -220.0
offset_top = -180.0
offset_right = 220.0
offset_bottom = 180.0
grow_horizontal = 2
grow_vertical = 2

[node name="Margin" type="MarginContainer" parent="CenterPanel"]
theme_override_constants/margin_left = 24
theme_override_constants/margin_top = 24
theme_override_constants/margin_right = 24
theme_override_constants/margin_bottom = 24

[node name="VBox" type="VBoxContainer" parent="CenterPanel/Margin"]
theme_override_constants/separation = 14

[node name="TitleLabel" type="Label" parent="CenterPanel/Margin/VBox"]
theme_override_font_sizes/font_size = 28
text = "Login"
horizontal_alignment = 1

[node name="SubtitleLabel" type="Label" parent="CenterPanel/Margin/VBox"]
theme_override_colors/font_color = Color(0.55, 0.55, 0.55, 1)
theme_override_font_sizes/font_size = 14
text = "Sign in to enter the office"
horizontal_alignment = 1

[node name="UsernameRow" type="HBoxContainer" parent="CenterPanel/Margin/VBox"]
theme_override_constants/separation = 12

[node name="Label" type="Label" parent="CenterPanel/Margin/VBox/UsernameRow"]
custom_minimum_size = Vector2(90, 0)
text = "Username"

[node name="LineEdit" type="LineEdit" parent="CenterPanel/Margin/VBox/UsernameRow"]
size_flags_horizontal = 3
placeholder_text = "Enter username"

[node name="PasswordRow" type="HBoxContainer" parent="CenterPanel/Margin/VBox"]
theme_override_constants/separation = 12

[node name="Label" type="Label" parent="CenterPanel/Margin/VBox/PasswordRow"]
custom_minimum_size = Vector2(90, 0)
text = "Password"

[node name="LineEdit" type="LineEdit" parent="CenterPanel/Margin/VBox/PasswordRow"]
size_flags_horizontal = 3
secret = true
placeholder_text = "Enter password"

[node name="ErrorLabel" type="Label" parent="CenterPanel/Margin/VBox"]
theme_override_colors/font_color = Color(0.85, 0.3, 0.3, 1)
